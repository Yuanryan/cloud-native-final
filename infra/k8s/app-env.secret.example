# Kubernetes Secret「app-env」欄位參考（勿 commit 真實值）
# 建立方式見 .github/env-and-secrets.md 或 infra/k8s/README.md
#
# kubectl create secret generic app-env -n safety-demo \
#   --from-literal=DATABASE_URL='postgresql://USER:PASS@HOST:5432/DB?schema=public' \
#   --from-literal=DIRECT_URL='postgresql://USER:PASS@HOST:5432/DB?schema=public' \
#   --from-literal=JWT_SECRET='replace-with-long-random-string' \
#   --from-literal=JWT_EXPIRES_SEC='28800' \
#   --from-literal=PORT='3000' \
#   --from-literal=REDIS_URL='redis://HOST:6379' \
#   --from-literal=QUEUE_DASHBOARD_PASSWORD='replace-with-strong-password' \
#   --from-literal=INTERNAL_API_TOKEN='replace-with-random-string'

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_SEC=28800
PORT=3000
REDIS_URL=redis://localhost:6379
QUEUE_DASHBOARD_PASSWORD=replace-with-strong-password
INTERNAL_API_TOKEN=replace-with-random-string
