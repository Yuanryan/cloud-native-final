{
  "name": "employee-safety-response",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"pnpm --filter api start:dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter api build && pnpm --filter web build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter api test",
    "test:cov": "pnpm --filter api test:cov",
    "test:e2e": "pnpm --filter api test:e2e",
    "test:e2e:web": "pnpm --filter web test:e2e",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:seed": "pnpm --filter api exec prisma db seed",
    "db:generate": "pnpm --filter api exec prisma generate",
    "prepare": "pnpm --filter api exec prisma generate"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
