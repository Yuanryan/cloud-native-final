# Copy to .env — 必須為 postgresql://（migrate / seed 不支援 prisma+postgres://）
#
# Prisma 需要兩個變數（schema 已設 directUrl）：
# - DATABASE_URL：執行期查詢
# - DIRECT_URL：migrate / introspection；本機 Docker 兩行填同一條即可
#
# --- 本機 / Docker（兩行相同）---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
#
# --- Supabase：若直連 db.xxx.supabase.co:5432 出現 P1001（網路/IPv4）---
# 請用 Dashboard 右上角 Connect → 選 **ORM: Prisma** 或 **Session pooler**，
# 主機為 *.pooler.supabase.com、port **5432**（Session），不要只用 db.* 直連。
# 密碼含特殊字元請做 URL encode。
# 兩個變數可先填同一條 Session pooler URI（結尾加 ssl）：
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# 若官方給「Transaction」用 port 6543，請在字尾加 &pgbouncer=true（較適合 serverless；本 Nest 專案可先兩行都用 Session 5432 最省事）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me
# 秒數；程式會 parse 成數字再給 JWT。勿依賴「純字串」直傳 jsonwebtoken（會被當成毫秒）。
JWT_EXPIRES_SEC=28800
PORT=3000
