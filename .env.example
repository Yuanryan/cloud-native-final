# 本機 Docker Postgres；雲端課程可改為 Neon/Supabase/RDS 等提供的 postgresql://…（常加 ?sslmode=require）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
# apps/api 的 Prisma schema 需要 DIRECT_URL；本機兩行相同即可
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_SEC=28800
PORT=3000

# Frontend：本機請複製到 apps/web/.env.local（Next 只讀 apps/web 底下 env）
# API 在 3000、next dev 在 3001 時：
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# 經由 Docker Nginx 時改為：http://localhost/api/v1
